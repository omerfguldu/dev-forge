{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "nextjs",
    "jsx-a11y",
    "import"
  ],
  "categories": {
    "correctness": "error",
    "perf": "warn"
  },
  "rules": {},
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["context/**"]
}
