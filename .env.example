# Umami analytics (privacy-first, cookie-free — build-plan.md 7.2).
# Leave unset to disable analytics entirely.
# Self-hosted: script URL is your instance's own domain, e.g. https://analytics.example.com/script.js
# Umami Cloud: https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
